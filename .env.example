# US Debt Clock Configuration

# FRED API Key (get from https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_KEY=your_fred_api_key_here

# Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=-1002000000000

DISCORD_WEBHOOK_URL=

# Resend Email API (optional, for email alerts)
RESEND_API_KEY=

# Stripe (for premium tier)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Server
HOST=0.0.0.0
PORT=8500
